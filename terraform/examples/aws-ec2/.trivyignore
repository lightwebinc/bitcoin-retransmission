# Trivy ignore file for the aws-ec2 example.
# These findings are intentional design choices for a public Bitcoin ingress
# proxy and are not appropriate to enforce on example/demo Terraform code.

# Security groups open to 0.0.0.0/0 and ::/0
# - BSV UDP ingress port must accept connections from any source (public proxy)
# - BGP port open because the peer IP is not known at deploy time
# - All-egress rules are standard for outbound-unrestricted nodes
AVD-AWS-0104

# EC2 instance IMDSv2 not enforced (no metadata_options block)
# Example omits this for brevity; production deployments should add it.
AVD-AWS-0028

# Root block device not encrypted
# Example omits KMS key config for simplicity.
AVD-AWS-0131

# Subnet map_public_ip_on_launch = true
# Public subnets in this example are intentionally public-facing.
AVD-AWS-0164

# Security group allows ingress from 0.0.0.0/0 to port 22
# SSH access is needed for administration; production should restrict source IPs.
AVD-AWS-0107

# AWS:015: Missing description for variable
AVD-AWS-0125
