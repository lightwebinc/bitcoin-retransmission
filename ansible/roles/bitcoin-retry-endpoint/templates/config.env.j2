# bitcoin-retry-endpoint environment configuration
# Managed by Ansible — do not edit manually

MC_IFACE={{ mc_iface }}
LISTEN_PORT={{ listen_port }}
NACK_PORT={{ nack_port }}
EGRESS_IFACE={{ egress_iface }}
EGRESS_PORT={{ egress_port }}
SHARD_BITS={{ shard_bits }}
MC_SCOPE={{ mc_scope }}
MC_BASE_ADDR={{ mc_base_addr }}
CACHE_BACKEND={{ cache_backend }}
REDIS_ADDR={{ redis_addr }}
CACHE_TTL={{ cache_ttl }}
CACHE_MAX_KEYS={{ cache_max_keys }}
DEDUP_WINDOW={{ dedup_window }}
RL_IP_RATE={{ rl_ip_rate }}
RL_IP_BURST={{ rl_ip_burst }}
RL_CHAIN_RATE={{ rl_chain_rate }}
RL_CHAIN_WINDOW={{ rl_chain_window }}
RL_SEQUENCE_MAX={{ rl_sequence_max }}
RL_SEQUENCE_WINDOW={{ rl_sequence_window }}
RL_GROUP_RATE={{ rl_group_rate }}
RL_GROUP_BURST={{ rl_group_burst }}
NUM_WORKERS={{ num_workers }}
METRICS_ADDR={{ metrics_addr }}
OTLP_ENDPOINT={{ otlp_endpoint }}
OTLP_INTERVAL={{ otlp_interval }}
DRAIN_TIMEOUT={{ drain_timeout }}
INSTANCE_ID={{ instance_id }}
DEBUG={{ 'true' if retry_debug else 'false' }}

NACK_ADDR={{ nack_addr }}

# Beacon configuration (BRC-126)
BEACON_ENABLED={{ 'true' if beacon_enabled else 'false' }}
BEACON_TIER={{ beacon_tier }}
BEACON_PREFERENCE={{ beacon_preference }}
BEACON_INTERVAL={{ beacon_interval }}
BEACON_SCOPE={{ beacon_scope }}
BEACON_FLAGS_UNICAST={{ 'true' if beacon_flags_unicast else 'false' }}
BEACON_FLAGS_MULTICAST={{ 'true' if beacon_flags_multicast else 'false' }}
BEACON_FLAGS_DRAINING={{ 'true' if beacon_flags_draining else 'false' }}
SUPPRESS_ACK={{ 'true' if suppress_ack else 'false' }}
SUPPRESS_MISS={{ 'true' if suppress_miss else 'false' }}
