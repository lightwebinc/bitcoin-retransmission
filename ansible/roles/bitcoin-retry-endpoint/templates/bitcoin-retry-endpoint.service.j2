[Unit]
Description=Bitcoin Retry Endpoint
Documentation=https://github.com/lightwebinc/bitcoin-retry-endpoint
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ retry_user }}
Group={{ retry_group }}
EnvironmentFile=/etc/bitcoin-retry-endpoint/config.env
ExecStart={{ retry_bin_dir }}/bitcoin-retry-endpoint
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
LimitNOFILE=65536

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths={{ retry_install_dir }}
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
